# Supabase Configuration (Required for client & server)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Admin Configuration (Required for server-side auth & password reset bypass RLS)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Gemini AI API Configuration (Required for AI assistant /api/chat)
GEMINI_API_KEY=your_gemini_api_key

# Setup Verification Secret (Required for /api/setup/admin)
SETUP_SECRET=your_admin_setup_endpoint_secret_key
